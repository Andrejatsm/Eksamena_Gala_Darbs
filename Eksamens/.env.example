GEMINI_API_KEY=your_gemini_api_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# SMTP email settings for PHPMailer-style app password use
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
