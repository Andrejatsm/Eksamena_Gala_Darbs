.env
.env.*
!.env.example
includes/.saprasts_key
vendor/

# Local editor/deploy configs that may contain credentials
.vscode/sftp.json
.vscode/ftp-sync.json
.vscode/*.json
.vscode/settings.json

# SFTP/FTP connection managers and sync configs
sftp-config.json
*.sftp.json
.ftpsync*
.ftp*
ftp-sync.json

# Database connection configs and local logins
config/database.php
config/db.php
includes/db_local.php
includes/db.local.php
*db_config*.php
*database_config*.php
.db_pass
.db_password
db.config.php

# Secrets and private keys
*.pem
*.key
*.p12
*.pfx
*.crt
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Local credentials and secret dumps
*.secret
*.secrets
*.credentials

# Logs and debug output
*.log
error_log
php_errorlog

# Runtime user-generated files (potentially sensitive)
uploads/profile_images/*
uploads/certificates/*
!uploads/profile_images/.gitkeep
!uploads/certificates/.gitkeep

# Database exports/backups (can contain real user data)
database/*backup*.sql
database/*dump*.sql
database/*export*.sql
database/*.sql.gz
database/*.dump
database/*.bak
database/local/
database/tmp/
